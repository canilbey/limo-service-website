# Public API URL for the booking + admin client (no trailing slash)
VITE_API_URL=http://localhost:3001

# Google Maps JavaScript API key (Maps, Places, Directions must be enabled)
VITE_GOOGLE_MAPS_API_KEY=

# Google Ads conversion label (Goals > Conversions > Tag setup) for booking submit events
VITE_GOOGLE_ADS_CONVERSION_LABEL=
