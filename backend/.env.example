# Server
PORT=3001
NODE_ENV=development

# SQLite database file path (relative to backend working directory)
DB_PATH=./data/limo.db

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars

# CORS: comma-separated allowed origins (no spaces), or * for dev only
CORS_ORIGIN=http://localhost:5173

# Set to 1 when running behind Nginx or any reverse proxy (fixes express-rate-limit ValidationError)
TRUST_PROXY=

# Admin seed (run: npm run seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Google Ads API (optional — admin "Google Ads" page and conversion label for frontend)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
# Optional: manager (MCC) account ID when accessing a client account
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Stored for ops reference; booking conversion uses VITE_GOOGLE_ADS_CONVERSION_LABEL on the frontend
GOOGLE_ADS_CONVERSION_LABEL=

# Email notifications (new booking → NOTIFICATION_EMAIL).
#
# Option A — Gmail / Google Workspace OAuth2 (recommended, no App Password needed):
#   1. Enable Gmail API in Google Cloud Console for your project.
#   2. Add https://developers.google.com/oauthplayground to OAuth Client authorized redirect URIs.
#   3. Open OAuth Playground → Settings → "Use your own OAuth credentials" → enter Client ID/Secret.
#   4. Select Gmail API v1 scope: https://mail.google.com/ → Authorize → Exchange for tokens → copy Refresh Token.
#   5. After changing .env, restart with: pm2 restart limo-api --update-env
#   (If switching from password to OAuth2, remove EMAIL_PASS or leave empty — stale PM2 env was fixed in server.ts via dotenv override.)
# EMAIL_SERVICE=gmail
# EMAIL_USER=info@yourdomain.com
# EMAIL_OAUTH2_CLIENT_ID=
# EMAIL_OAUTH2_CLIENT_SECRET=
# EMAIL_OAUTH2_REFRESH_TOKEN=
#
# Option B — Gmail App Password (requires 2-Step Verification enabled on the Google account):
# EMAIL_SERVICE=gmail
# EMAIL_USER=youraccount@gmail.com
# EMAIL_PASS=xxxx xxxx xxxx xxxx
#
# Option C — Explicit SMTP host (non-Gmail providers):
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
EMAIL_SERVICE=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_OAUTH2_CLIENT_ID=
EMAIL_OAUTH2_CLIENT_SECRET=
EMAIL_OAUTH2_REFRESH_TOKEN=
EMAIL_FROM=Info@budgetlimonj.com
# Booking alerts go here. If this equals EMAIL_FROM, Gmail usually shows the message only under Sent, not Inbox.
# Set NOTIFICATION_BCC to another address (comma-separated) for a true Inbox copy, or use a different NOTIFICATION_EMAIL.
NOTIFICATION_EMAIL=Info@budgetlimonj.com
NOTIFICATION_BCC=
