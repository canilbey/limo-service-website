# Server
PORT=3001
NODE_ENV=development

# SQLite database file path (relative to backend working directory)
DB_PATH=./data/limo.db

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars

# CORS: comma-separated allowed origins (no spaces), or * for dev only
CORS_ORIGIN=http://localhost:5173

# Admin seed (run: npm run seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Google Ads API (optional — admin "Google Ads" page and conversion label for frontend)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
# Optional: manager (MCC) account ID when accessing a client account
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Stored for ops reference; booking conversion uses VITE_GOOGLE_ADS_CONVERSION_LABEL on the frontend
GOOGLE_ADS_CONVERSION_LABEL=
